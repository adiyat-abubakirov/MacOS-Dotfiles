#            --subscribe front_app front_app_switched

##### Adding Right Items #####
# In the same way as the left items we can add items to the right side.
# Additional position (e.g. center) are available, see:
# https://felixkratz.github.io/SketchyBar/config/items#adding-items-to-sketchybar

# datetime
sketchybar --add item datetime right \
           --set datetime update_freq=10 icon.color=0xffb8bb26 icon=  script="$PLUGIN_DIR/datetime.sh"
# battery
sketchybar --add item battery right \
           --set battery update_freq=240 script="$PLUGIN_DIR/battery.sh" \
           --subscribe battery system_woke power_source_change
# volume
sketchybar --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" icon.color=0xfffe8019 \
           --subscribe volume volume_change

# cpu-temp
sketchybar --add item cpu_temp center \
           --set cpu_temp update_freq=240 icon.color=0xff458588 icon= script="$PLUGIN_DIR/cpu_temp.sh"

# cpu-usage
sketchybar --add item cpu_usage center \
           --set cpu_usage update_freq=240 icon.color=0xfffe8019 icon= script="$PLUGIN_DIR/cpu_usage.sh"

# gpu-temp
sketchybar --add item gpu_temp center \
           --set gpu_temp update_freq=240 icon.color=0xff689d6a icon= script="$PLUGIN_DIR/gpu_temp.sh"

# ram
sketchybar --add item ram center \
           --set ram update_freq=240 icon.color=0xfffabd2f icon= script="$PLUGIN_DIR/ram.sh"

# bluetooth
sketchybar --add item bluetooth right \
  --set bluetooth \
    script="$PLUGIN_DIR/bluetooth.sh" \
    icon.color=0xff458588 \
    icon= \
  --add event bluetooth_update "com.apple.bluetooth.status" \
  --subscribe bluetooth bluetooth_update

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update
